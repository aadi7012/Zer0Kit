rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Validation Blueprint for Resume
    function isValidResume(data) {
       return data.keys().hasAll(['userId', 'createdAt', 'updatedAt'])
              && data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128
              && data.createdAt is number
              && data.updatedAt is number
              && (!('fullName' in data) || (data.fullName is string && data.fullName.size() <= 100))
              && (!('title' in data) || (data.title is string && data.title.size() <= 100))
              && (!('email' in data) || (data.email is string && data.email.size() <= 100))
              && (!('phone' in data) || (data.phone is string && data.phone.size() <= 50))
              && (!('summary' in data) || (data.summary is string && data.summary.size() <= 2000))
              && (!('experience' in data) || (data.experience is list && data.experience.size() <= 50))
              && (!('education' in data) || (data.education is list && data.education.size() <= 50));
    }

    match /resumes/{resumeId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() 
                    && isValidId(resumeId)
                    && isValidResume(incoming()) 
                    && incoming().userId == request.auth.uid
                    && incoming().keys().size() <= 10;
                    
      allow update: if isSignedIn() 
                    && existing().userId == request.auth.uid
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && isValidResume(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt', 'fullName', 'title', 'email', 'phone', 'summary', 'experience', 'education']);

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
